# =============================================================================
# Cognitive Market Engine — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!
# =============================================================================

# NewsAPI key (free tier: https://newsapi.org)
NEWSAPI_KEY=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable file logging (set to a path, or leave empty for console-only)
LOG_FILE=

# Default asset to track
DEFAULT_ASSET=BTC

# Database path (SQLite) — leave empty for in-memory
DATABASE_PATH=

# Dashboard port (Streamlit)
DASHBOARD_PORT=8501
